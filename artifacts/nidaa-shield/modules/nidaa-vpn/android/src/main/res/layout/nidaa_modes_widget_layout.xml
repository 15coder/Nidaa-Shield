<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/nidaa_widget_bg"
    android:layoutDirection="rtl">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <View
            android:id="@+id/modes_status_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/nidaa_dot_inactive"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/modes_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="نداء شايلد"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textDirection="rtl" />

        <TextView
            android:id="@+id/modes_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#8B95A1"
            android:textSize="10sp"
            android:textDirection="rtl"
            android:gravity="end"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- 4 mode tiles -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:weightSum="4"
        android:layoutDirection="rtl">

        <LinearLayout
            android:id="@+id/btn_smart"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="6dp"
            android:padding="6dp"
            android:background="@drawable/nidaa_widget_btn_bg">
            <View
                android:id="@+id/smart_icon_bg"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/nidaa_mode_chip_inactive" />
            <TextView
                android:id="@+id/smart_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="الذكي"
                android:textColor="#F4F4F6"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginTop="6dp"
                android:textDirection="rtl" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_gaming"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="6dp"
            android:padding="6dp"
            android:background="@drawable/nidaa_widget_btn_bg">
            <View
                android:id="@+id/gaming_icon_bg"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/nidaa_mode_chip_inactive" />
            <TextView
                android:id="@+id/gaming_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="الألعاب"
                android:textColor="#F4F4F6"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginTop="6dp"
                android:textDirection="rtl" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_family"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="6dp"
            android:padding="6dp"
            android:background="@drawable/nidaa_widget_btn_bg">
            <View
                android:id="@+id/family_icon_bg"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/nidaa_mode_chip_inactive" />
            <TextView
                android:id="@+id/family_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="العائلة"
                android:textColor="#F4F4F6"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginTop="6dp"
                android:textDirection="rtl" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_military"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="6dp"
            android:background="@drawable/nidaa_widget_btn_bg">
            <View
                android:id="@+id/military_icon_bg"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/nidaa_mode_chip_inactive" />
            <TextView
                android:id="@+id/military_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="العسكرية"
                android:textColor="#F4F4F6"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginTop="6dp"
                android:textDirection="rtl" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
