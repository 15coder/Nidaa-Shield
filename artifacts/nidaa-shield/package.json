{
  "name": "@workspace/nidaa-shield",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "EXPO_PACKAGER_PROXY_URL=https://$REPLIT_EXPO_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_REPL_ID=$REPL_ID REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_DEV_DOMAIN pnpm exec expo start --localhost --port $PORT",
    "build": "node scripts/build.js",
    "serve": "node server/serve.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "doctor": "npx --yes expo-doctor@latest",
    "preflight": "CI=1 pnpm exec expo install --check && tsc -p tsconfig.json --noEmit && CI=1 npx --yes expo-doctor@latest",
    "clean": "rm -rf node_modules .expo dist android ios && pnpm install && pnpm exec expo start --clear",
    "ota:preview": "pnpm exec eas update --branch preview --auto",
    "ota:production": "pnpm exec eas update --branch production --auto",
    "eas-build-pre-install": "echo \"[eas pre-install] using $(node -v) / $(npm -v) on EAS\"",
    "eas-build-post-install": "CI=1 pnpm exec expo install --check && CI=1 pnpm exec expo prebuild --clean --platform android --no-install"
  },
  "expo": {
    "autolinking": {
      "nativeModulesDir": "./modules"
    }
  },
  "dependencies": {
    "@expo-google-fonts/cairo": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.27",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.9",
    "expo-constants": "~18.0.11",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.10",
    "expo-notifications": "^0.32.16",
    "expo-router": "~6.0.17",
    "expo-splash-screen": "~31.0.12",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.1.10",
    "babel-plugin-react-compiler": "^19.0.0-beta-e993439-20250117",
    "typescript": "~5.9.2"
  }
}
